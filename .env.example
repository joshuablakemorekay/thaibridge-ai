# Copy this file to .env and fill in your values
# .env is gitignored — never commit real secrets

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: set to "production" in live environments
FLASK_ENV=development

# Developer mode password
DEVELOPER_PASSWORD=your-password-here

# Stripe (TEST/sandbox keys only — find them at https://dashboard.stripe.com/test/apikeys)
# Never put live sk_live_... keys here.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# From `stripe listen` (local) or the webhook endpoint settings in the dashboard.
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal (SANDBOX credentials only — https://developer.paypal.com/dashboard/applications/sandbox)
# Create a sandbox app, then copy its Client ID and Secret here.
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
# 'sandbox' for testing, 'live' only when you're ready to take real money.
PAYPAL_MODE=sandbox
